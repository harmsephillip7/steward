# --- Local development + Neon PostgreSQL ---
# Get your Neon connection string from https://console.neon.tech
DATABASE_URL=postgresql://user:pass@ep-xxxx.neon.tech/neondb?sslmode=require&channel_binding=require
NODE_ENV=development
JWT_SECRET=change_me_in_production
FRONTEND_URL=http://localhost:3000

# --- Production (Railway) ---
# NODE_ENV=production
# DATABASE_URL=<Neon production branch connection string>
# JWT_SECRET=<openssl rand -hex 64>
# FRONTEND_URL=https://your-app.vercel.app
